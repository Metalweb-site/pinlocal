# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_64_character_hex_secret_here_generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRES=30d
JWT_REFRESH_EXPIRES=90d

# ─── Database (Supabase or PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/pinlocal
DB_POOL_MAX=10
DNS_RESULT_ORDER=ipv4first

# ─── Redis (Upstash or local) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MSG91 (OTP / SMS) [Optional in development] ────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=PINLOC
SUPER_ADMIN_PHONES=8888888888

# ─── Cloudflare R2 (media) [Optional in development] ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pinlocal-media
CDN_BASE_URL=https://media.yourdomain.com

# Media processing. Required for video upload validation/compression/thumbnails.
# On most Linux servers, install ffmpeg and leave these as-is.
MEDIA_FFMPEG_PATH=ffmpeg
MEDIA_FFPROBE_PATH=ffprobe

# Optional pincode import tuning
PINCODE_DATA_FILE=./data/pincodes/india-pincodes.csv
PINCODE_NEIGHBOR_RADIUS_KM=8
PINCODE_NEIGHBOR_MAX_COUNT=12
PINCODE_IMPORT_BATCH_SIZE=500
PINCODE_IMPORT_MODE=replace
LOCALITY_MIN_CONTRIBUTORS=10
LOCALITY_MIN_WIN_SHARE=0.6
LOCALITY_MIN_LEAD_SHARE=0.2
LOCALITY_MIN_LEAD_WEIGHT=3
LOCALITY_CONSENSUS_MAX_DISTANCE_KM=6
