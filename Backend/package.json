{
  "name": "pinlocal-server",
  "version": "1.0.0",
  "description": "PinLocal hyperlocal community platform — backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/db/migrations/index.ts",
    "seed": "ts-node src/db/seed/index.ts",
    "seed:sample": "ts-node src/db/seed/index.ts --sample",
    "import:pincodes": "ts-node src/db/seed/index.ts",
    "recompute:localities": "ts-node src/db/locality-consensus/index.ts",
    "cleanup:pincode-boundaries": "ts-node src/db/cleanup-pincode-boundaries/index.ts",
    "reset:db": "ts-node src/db/reset/index.ts",
    "reset:db:all": "ts-node src/db/reset/index.ts --all"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.8.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-socket.io": "^5.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
